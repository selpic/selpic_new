<Window x:Class="selpic_new.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SELPIC PDF"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        Topmost="True"
        Cursor="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="810"/>
            <RowDefinition x:Name="Row1" Height="540"/>
            <RowDefinition x:Name="Row2" Height="570"/>
        </Grid.RowDefinitions>

        <!-- 스크린1: 광고 (이미지 + WebView2 영상) -->
        <Grid Grid.Row="0" Background="Black">
            <Image x:Name="AdImage1" Stretch="Fill" Visibility="Visible"/>
            <wv2:WebView2 x:Name="AdWebView" Visibility="Collapsed"/>
        </Grid>

        <!-- 중간: 상태 표시 영역 -->
        <Grid Grid.Row="1" Background="Black">
            <!-- 기본 안내 (QR + 지점번호 + 지점명) -->
            <Grid x:Name="GuidePanel" Visibility="Visible">
                <Image x:Name="GuideImage" Stretch="Fill"/>
                <!-- 히든 설정 버튼 (좌측 상단) -->
                <Button x:Name="HiddenSetupBtn" 
                        Width="50" Height="50" 
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Opacity="0" Cursor="Arrow"
                        Click="HiddenSetupBtn_Click"/>
                <Canvas>
                    <Image x:Name="QrImage" Stretch="Uniform"/>
                    <TextBlock x:Name="BranchCodeText" FontWeight="Bold"/>
                    <TextBlock x:Name="BranchNameText" TextWrapping="NoWrap"/>
                </Canvas>
            </Grid>
            <!-- 에러 -->
            <Grid x:Name="ErrorPanel" Visibility="Collapsed">
                <Image x:Name="ErrorImage" Stretch="Fill"/>
                <TextBlock x:Name="ErrorText" 
                           Foreground="White" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,60"/>
            </Grid>
            <!-- 연결 중 -->
            <Image x:Name="LoadingImage" Stretch="Fill" Visibility="Collapsed"/>
        </Grid>

        <!-- 스크린2: 웹 광고 (WebView2) -->
        <Grid Grid.Row="2" Background="Black">
            <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>
            <TextBlock x:Name="Screen2Text" 
                       Text="SELPIC" 
                       Foreground="White" 
                       FontSize="48" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>