<Window x:Class="selpic_new.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SELPIC 설정"
        Width="420" Height="710"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#F0F0F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 지점 코드 검색 -->
        <GroupBox Grid.Row="0" Header="▶ 지점 코드 검색" Margin="0,0,0,10" Padding="10">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="SearchBtn" Content="검색" Width="60" DockPanel.Dock="Right" 
                            Margin="8,0,0,0" Click="SearchBtn_Click"/>
                    <TextBox x:Name="BranchCodeInput" FontSize="14"/>
                </DockPanel>
                <TextBox x:Name="BranchInfoText" Height="60" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontSize="13" Background="#FFFFFF"/>
            </StackPanel>
        </GroupBox>

        <!-- 기기 타입 -->
        <GroupBox Grid.Row="1" Header="▶ 기기 타입" Margin="0,0,0,10" Padding="10">
            <ComboBox x:Name="DeviceTypeCombo" FontSize="13">
                <ComboBoxItem Content="A" Tag="A"/>
                <ComboBoxItem Content="B" Tag="B"/>
                <ComboBoxItem Content="C" Tag="C" IsSelected="True"/>
            </ComboBox>
        </GroupBox>

        <!-- 프린터 선택 -->
        <GroupBox Grid.Row="2" Header="Printer Type" Margin="0,0,0,10" Padding="10">
            <ComboBox x:Name="PrinterCombo" FontSize="13">
                <ComboBoxItem Content="Brother HL-L9430CDN series" IsSelected="True"/>
                <ComboBoxItem Content="Brother HL-L8360CDW series"/>
                <ComboBoxItem Content="Brother HL-L3280CDW series"/>
            </ComboBox>
        </GroupBox>

        <!-- GhostScript 경로 -->
        <GroupBox Grid.Row="3" Header="GhostScript 경로" Margin="0,0,0,10" Padding="10">
            <TextBox x:Name="GhostScriptInput" FontSize="12"/>
        </GroupBox>

        <!-- 결제 정보 -->
        <GroupBox Grid.Row="4" Header="Payment Info" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="제휴번호" VerticalAlignment="Center" Margin="0,0,0,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="PaymentCodeInput" FontSize="13" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="단말코드" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TerminalCodeInput" FontSize="13"/>
            </Grid>
        </GroupBox>

        <!-- 통신주기 / 재시도 -->
        <GroupBox Grid.Row="5" Header="System" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="통신주기" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="PollIntervalInput" Width="50" FontSize="13" TextAlignment="Center"/>
                <TextBlock Text="초" VerticalAlignment="Center" Margin="4,0,20,0"/>
                <TextBlock Text="재시도" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="RetryCountInput" Width="50" FontSize="13" TextAlignment="Center"/>
                <TextBlock Text="회" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 바로가기 / 자동실행 -->
        <GroupBox Grid.Row="6" Header="▶ 시스템 등록" Margin="0,0,0,10" Padding="10">
            <StackPanel>
                <CheckBox x:Name="ShortcutCheck" Content="바탕화면 바로가기 생성" FontSize="13" Margin="0,0,0,6"/>
                <CheckBox x:Name="AutoStartCheck" Content="부팅 시 자동실행" FontSize="13"/>
            </StackPanel>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RestartBtn" Content="저장 후 재시작" Width="110" Height="32"
                    Margin="0,0,8,0" Click="RestartBtn_Click" FontWeight="Bold"/>
            <Button x:Name="SaveBtn" Content="저장 후 종료" Width="100" Height="32"
                    Margin="0,0,8,0" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="취소" Width="80" Height="32"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>